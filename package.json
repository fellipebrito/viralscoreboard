{
  "name": "viralboard",
  "version": "0.1.0",
  "private": true,
  "description": "World Champions' Drought Board — static GitHub Pages site.",
  "scripts": {
    "build:nations": "node scripts/build-nations.mjs",
    "build:share": "node scripts/build-share-pages.mjs",
    "build:ulv-share": "node scripts/build-ulv-share.mjs",
    "check:flags": "node scripts/check-flags.mjs",
